# Split.io API Keys
# Copy this file to .env and fill in your actual keys

# Server-side key (KEEP SECRET - do not commit to git)
# Get this from: Split.io Dashboard -> Admin Settings -> API Keys -> SDK (Server-side)
SPLIT_API_KEY=your_server_side_api_key_here

# Flask Secret Key
# Generate a random secret key for production
SECRET_KEY=your_secret_key_here

# Database — SQLite is the default (no DATABASE_URL, POSTGRES_DATABASE=off).
# PostgreSQL when postgres_database flag is on AND DATABASE_URL is set.
#
# Native local Postgres (Homebrew postgresql@16 — see docs/LOCAL_POSTGRES.md):
# DATABASE_URL=postgresql://YOUR_OS_USER@localhost:5432/quantum_bank
# POSTGRES_DATABASE=on
#
# Managed Postgres (Render, GCP Cloud SQL, etc. — SSL often required):
# DATABASE_URL=postgresql://user:pass@host:5432/quantum_bank?sslmode=require
# POSTGRES_DATABASE=on
